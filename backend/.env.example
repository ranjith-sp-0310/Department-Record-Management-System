# ============================================================================
# DRMS Backend Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================

# Basic Connection Parameters
DB_USER=postgres
DB_PASS=your_secure_database_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=drms_db

# ============================================================================
# DATABASE CONNECTION POOL CONFIGURATION
# ============================================================================
# IMPORTANT: Align with PostgreSQL max_connections setting
# Default PostgreSQL max_connections: 100
# Formula: max_connections = (DB_POOL_MAX × num_app_instances) + buffer
#
# DEVELOPMENT:
#   DB_POOL_MAX=20  (single instance, plenty for testing)
#   DB_POOL_MIN=2   (minimal idle connections)
#
# PRODUCTION (Single Server):
#   DB_POOL_MAX=50  (adjust based on concurrent users)
#   DB_POOL_MIN=10  (keep connections warm)
#
# PRODUCTION (Multiple Instances - e.g., 3 app servers):
#   DB_POOL_MAX=30  (3 instances × 30 = 90, leaves 10 for admin)
#   DB_POOL_MIN=5   (per instance)
#
# PRODUCTION (High Traffic):
#   DB_POOL_MAX=80
#   DB_POOL_MIN=20
#   - Ensure PostgreSQL max_connections >= 100
#   - Monitor with: SELECT * FROM pg_stat_activity;
#
# Timeouts:
#   DB_IDLE_TIMEOUT_MS: Close idle connections (default: 30s dev, 60s prod)
#   DB_CONNECTION_TIMEOUT_MS: Wait time to acquire connection (default: 5s dev, 10s prod)
#   DB_STATEMENT_TIMEOUT_MS: Max query execution time (default: 30s)
#   DB_QUERY_TIMEOUT_MS: Overall query timeout (default: 60s)
#
# Pool Health Monitoring:
#   - Healthy: utilization < 70%, errors < 5%
#   - Warning: utilization 70-90%, errors 5-10%
#   - Critical: utilization > 90%, errors > 10%, or waiting > 5
# ============================================================================

# Maximum number of connections in pool
DB_POOL_MAX=20

# Minimum number of idle connections to maintain
DB_POOL_MIN=2

# Milliseconds before closing idle connections
DB_IDLE_TIMEOUT_MS=30000

# Milliseconds to wait for connection from pool
DB_CONNECTION_TIMEOUT_MS=5000

# Maximum query execution time (prevents runaway queries)
DB_STATEMENT_TIMEOUT_MS=30000

# Overall query timeout
DB_QUERY_TIMEOUT_MS=60000

# ============================================================================
# EMAIL CONFIGURATION (SMTP)
# ============================================================================
# For Gmail: Use App Password (not your regular password)
# For Outlook/Office365: smtp-mail.outlook.com
# For SendGrid: smtp.sendgrid.net

EMAIL_HOST=smtp-mail.outlook.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your_secure_email_app_password

# Optional: Use Gmail service (alternative to SMTP)
# EMAIL_SERVICE=gmail

# Admin emails (comma-separated for multiple admins)
ADMIN_EMAILS=admin@example.com,admin2@example.com

# ============================================================================
# JWT & AUTHENTICATION
# ============================================================================
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate_a_64_character_random_secret_key_here_see_command_above

# OTP expiry in minutes
OTP_EXPIRY_MIN=5

# ============================================================================
# FILE STORAGE - Explicit Path Configuration
# ============================================================================
# IMPORTANT: Use ABSOLUTE paths in production to avoid file loss and permission errors
#
# DEVELOPMENT (relative path OK):
#   FILE_STORAGE_PATH=./uploads
#   FILE_STORAGE_PATH=uploads
#
# PRODUCTION (absolute path REQUIRED):
#   Linux/VPS:     FILE_STORAGE_PATH=/var/www/drms/uploads
#   Docker:        FILE_STORAGE_PATH=/app/uploads
#   Windows:       FILE_STORAGE_PATH=C:/drms/uploads
#   Cloud Storage: FILE_STORAGE_PATH=/mnt/storage/uploads
#
# Permissions Required (Linux/macOS):
#   - Directory must be readable and writable by Node.js process
#   - Recommended: chmod 755 /var/www/drms/uploads
#   - Owner: Same user running Node.js (or www-data for Nginx)
#
# The application will:
#   ✅ Create directory if missing (recursive)
#   ✅ Verify read/write permissions at startup
#   ✅ Fail fast in production if path is invalid
#   ⚠️  Warn in development (allows startup with issues)
#
FILE_STORAGE_PATH=./uploads

# Maximum file upload size in megabytes
FILE_SIZE_LIMIT_MB=50

# Allowed upload MIME types (comma-separated)
# Leave empty to allow all types (not recommended for production)
ALLOWED_FILE_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/zip,application/vnd.android.package-archive,application/x-msdownload,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation,image/png,image/jpeg

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=5000
NODE_ENV=development

# ============================================================================
# CORS CONFIGURATION - Environment-Based Strategy
# ============================================================================
# IMPORTANT: Different strategies for different environments
#
# DEVELOPMENT (default):
#   ENABLE_CORS=true
#   - Backend handles CORS with CORS_ORIGINS
#   - Frontend runs on different port (localhost:3000 or 5173)
#   - Direct API calls from browser
#
# PRODUCTION (with Nginx/Apache):
#   ENABLE_CORS=false
#   - Nginx/Apache handles CORS and /api proxying
#   - Frontend and backend served from same domain
#   - More secure and performant
#   - See nginx.conf.example for configuration
#
# PRODUCTION (without reverse proxy):
#   ENABLE_CORS=true
#   CORS_ORIGINS=https://your-production-domain.com
#   - Only when deploying to platforms like Heroku, Railway, Render
#   - Backend handles CORS directly
# ============================================================================

# Enable/disable CORS middleware (default: true)
# Set to 'false' in production when using Nginx/reverse proxy
ENABLE_CORS=true

# CORS allowed origins (comma-separated)
# Development: include all local dev servers
# Staging: include staging domain
# Production: specific production domain OR leave empty if ENABLE_CORS=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# ============================================================================
# PRODUCTION CONFIGURATION EXAMPLES
# ============================================================================

# Example 1: Production with Nginx (RECOMMENDED)
# ============================================================================
# NODE_ENV=production
# ENABLE_CORS=false           # Nginx handles CORS
# PORT=5000
# CORS_ORIGINS=               # Not needed
# DB_HOST=production-db.example.com
# JWT_SECRET=64_character_production_secret

# Example 2: Production with Platform (Heroku/Railway/Render)
# ============================================================================
# NODE_ENV=production
# ENABLE_CORS=true            # Backend handles CORS
# CORS_ORIGINS=https://your-app.example.com
# PORT=5000
# DB_HOST=platform-provided-db-url
# JWT_SECRET=64_character_production_secret

# Example 3: Staging Environment
# ============================================================================
# NODE_ENV=staging
# ENABLE_CORS=true
# CORS_ORIGINS=https://staging.your-app.example.com
# PORT=5000
# DB_HOST=staging-db.example.com
# JWT_SECRET=staging_secret_different_from_production

# ============================================================================
# SECURITY REMINDERS
# ============================================================================
# 1. Change ALL default passwords
# 2. Use strong, unique JWT_SECRET (minimum 32 characters)
# 3. Use Gmail App Passwords or SMTP with TLS
# 4. In production with Nginx: set ENABLE_CORS=false
# 5. In production without Nginx: limit CORS_ORIGINS to your domain only
# 6. Enable database SSL in production (add DB_SSL=true if supported)
# 7. Never commit this file with real credentials
# 8. Rotate secrets regularly (every 90 days recommended)
# ============================================================================
